DATABASE_URL="file:./dev.db"
ACCESS_TOKEN_SECRET="change-in-production"
REFRESH_TOKEN_SECRET="change-in-production"
PORT=3001
NODE_ENV=development

# Application URL (used in email links)
APP_URL=http://localhost:5173

# Anthropic AI (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Email / SMTP (optional — emails logged to console in dev when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tri-planner.fr

# CORS allowed origin (production)
CORS_ORIGIN=https://your-app-domain.com

# Production security
# COOKIE_SECURE=true

# Strava API — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3001/api/v1/strava/callback

# Sentry error tracking (optional) — https://sentry.io
SENTRY_DSN=
