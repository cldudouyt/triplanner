# Database — PostgreSQL
# Dev sans Docker : postgresql://postgres:monmdp@localhost:5432/triplan_dev
# Dev avec Docker : postgresql://postgres:postgres@localhost:5432/triplan_dev (docker-compose up)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/triplan_dev"

# PostgreSQL pour docker-compose.prod.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=triplan

# JWT Secrets — generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET="change-me-32-chars-minimum-random"
REFRESH_TOKEN_SECRET="change-me-32-chars-minimum-random-2"

# Server
PORT=3001
NODE_ENV=development

# CORS — URL du frontend
CORS_ORIGIN="http://localhost:5173"

# IA Anthropic (optionnel — console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Strava OAuth (optionnel — strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3001/api/v1/strava/callback

# Emails (optionnel — nodemailer)
# En dev, les emails sont loggés en console si SMTP non configuré
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Tri Planner <noreply@triplan.app>"

# App URL (pour les liens dans les emails)
APP_URL=http://localhost:5173

# Sentry (optionnel — sentry.io)
SENTRY_DSN=

# Production seulement
COOKIE_SECURE=false   # true en production (HTTPS obligatoire)
